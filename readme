### SOURCE
curl -i -X POST -H "Accept: application/json" -H "Content-Type: application/json" localhost:8083/connectors/ -d '{
 "name": "source-connector",  
  "config": {
    "connector.class": "io.debezium.connector.postgresql.PostgresConnector", 
    "database.hostname": "postgres-src", 
    "database.port": "5432", 
    "database.user": "alpha", 
    "database.password": "alpha123", 
    "database.dbname" : "alpha", 
    "plugin.name": "pgoutput",
    "topic.prefix": "test", 
    "table.include.list": "public.users,public.cities",
    "publication.name": "testpub",
    "tombstones.on.delete": "false",
    "poll.interval.ms": 500,
    "max.batch.size": 2048,
    "max.queue.size": 8192,
    "snapshot.fetch.size": 10240,
    "slot.max.retries": 6,
    "slot.retry.delay.ms": 10000,
    "retriable.restart.connector.wait.ms": 10000,
    "skipped.operations": "t"
  }
}'

### SINK DEBEZIUM
curl -i -X POST -H "Accept: application/json" -H "Content-Type: application/json" localhost:8083/connectors/ -d '{
  "name": "sink-connector",  
  "config": {
      "connector.class": "io.debezium.connector.jdbc.JdbcSinkConnector",  
      "tasks.max": "1",  
      "connection.url": "jdbc:postgresql://postgres-dst:5432/omega",  
      "connection.username": "omega",  
      "connection.password": "omega789",  
      "insert.mode": "upsert",  
      "delete.enabled": "true",  
      "primary.key.mode": "record_key",  
      "collection.name.format": "${source.schema}.${source.table}",
      "schema.evolution": "basic",  
      "use.time.zone": "UTC",  
      "topics": "test.public.users,test.public.cities" 
  }
}'

### SINK CONFLUENT
curl -i -X POST -H "Accept: application/json" -H "Content-Type: application/json" localhost:8083/connectors/ -d '{
  "name": "sink-connector",  
  "config": {
      "connector.class": "io.confluent.connect.jdbc.JdbcSinkConnector",  
      "tasks.max": "1",  
      "connection.url": "jdbc:postgresql://postgres-dst/omega",  
      "connection.user": "omega",  
      "connection.password": "omega789",  
      "insert.mode": "upsert",  
      "delete.enabled": "true",  
      "pk.mode": "record_key",  
      "table.name.format": "${topic}",
      "db.timezone": "UTC",  
      "timestamp.precision.mode": "microseconds",
      "auto.evolve": true,
      "topics": "omega.public.users_max" 
  }
}'



### DELETE
curl -i -X DELETE -H "Accept: application/json" localhost:8083/connectors/myconnector
